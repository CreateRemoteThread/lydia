#!/usr/bin/env python3

from __future__ import annotations

import json
from typing import Any, Dict, List, Optional

import requests


class OpenAICompletionClient:
    """
    Minimal OpenAI-compatible v1 chat completions client
    with support for tool calls.

    Compatible with:
      - OpenAI
      - Local OpenAI-compatible servers
      - vLLM
      - Ollama (OpenAI mode)
      - LM Studio
      - OpenRouter
      - etc.
    """

    def __init__(
        self,
        api_key: str,
        base_url: str = "https://api.openai.com/v1",
        model: str = "gpt-4.1-mini",
        timeout: int = 60,
    ):
        self.api_key = api_key
        self.base_url = base_url.rstrip("/")
        self.model = model
        self.timeout = timeout

    @property
    def headers(self) -> Dict[str, str]:
        return {
            "Authorization": f"Bearer {self.api_key}",
            "Content-Type": "application/json",
        }

    def chat_completion(
        self,
        messages: List[Dict[str, Any]],
        tools: Optional[List[Dict[str, Any]]] = None,
        tool_choice: Optional[Any] = None,
        temperature: float = 0.7,
        max_tokens: Optional[int] = None,
        extra_payload: Optional[Dict[str, Any]] = None,
    ) -> Dict[str, Any]:
        """
        Send a chat completion request.

        Args:
            messages:
                Standard OpenAI chat messages.

            tools:
                OpenAI tool definitions.

            tool_choice:
                "auto", "none", or explicit tool selection.

            temperature:
                Sampling temperature.

            max_tokens:
                Optional output token limit.

            extra_payload:
                Additional API-specific fields.

        Returns:
            Full API JSON response.
        """

        payload: Dict[str, Any] = {
            "model": self.model,
            "messages": messages,
            "temperature": temperature,
        }

        if tools:
            payload["tools"] = tools

        if tool_choice is not None:
            payload["tool_choice"] = tool_choice

        if max_tokens is not None:
            payload["max_tokens"] = max_tokens

        if extra_payload:
            payload.update(extra_payload)

        response = requests.post(
            f"{self.base_url}/chat/completions",
            headers=self.headers,
            json=payload,
            timeout=self.timeout,
        )

        response.raise_for_status()
        return response.json()

    def run_with_tools(
        self,
        user_message: str,
        tools: List[Dict[str, Any]],
        tool_implementations: Dict[str, Any],
        system_prompt: Optional[str] = None,
        max_round_trips: int = 5,
    ) -> str:
        """
        Full tool-calling loop.

        Args:
            user_message:
                User prompt.

            tools:
                OpenAI tool schemas.

            tool_implementations:
                Mapping of tool name -> callable.

            system_prompt:
                Optional system instruction.

            max_round_trips:
                Safety limit.

        Returns:
            Final assistant text response.
        """

        messages: List[Dict[str, Any]] = []

        if system_prompt:
            messages.append(
                {
                    "role": "system",
                    "content": system_prompt,
                }
            )

        messages.append(
            {
                "role": "user",
                "content": user_message,
            }
        )

        for _ in range(max_round_trips):

            response = self.chat_completion(
                messages=messages,
                tools=tools,
                tool_choice="auto",
            )

            assistant_message = response["choices"][0]["message"]

            messages.append(assistant_message)

            tool_calls = assistant_message.get("tool_calls")

            # No tool calls -> final response
            if not tool_calls:
                return assistant_message.get("content", "")

            # Execute each tool call
            for tool_call in tool_calls:

                tool_name = tool_call["function"]["name"]

                arguments_str = tool_call["function"].get("arguments", "{}")

                try:
                    arguments = json.loads(arguments_str)
                except json.JSONDecodeError:
                    arguments = {}

                if tool_name not in tool_implementations:
                    tool_result = {
                        "error": f"Unknown tool: {tool_name}"
                    }
                else:
                    try:
                        tool_result = tool_implementations[tool_name](
                            **arguments
                        )
                    except Exception as exc:
                        tool_result = {
                            "error": str(exc)
                        }

                messages.append(
                    {
                        "role": "tool",
                        "tool_call_id": tool_call["id"],
                        "name": tool_name,
                        "content": json.dumps(tool_result),
                    }
                )

        raise RuntimeError(
            "Maximum tool-calling rounds exceeded"
        )


# -------------------------------------------------------------------
# Example usage
# -------------------------------------------------------------------

def get_weather(city: str) -> Dict[str, Any]:
    fake_weather = {
        "Sydney": "22C and sunny",
        "London": "12C and rainy",
        "New York": "18C and cloudy",
    }

    return {
        "city": city,
        "forecast": fake_weather.get(city, "Unknown"),
    }


TOOLS = [
    {
        "type": "function",
        "function": {
            "name": "get_weather",
            "description": "Get weather for a city",
            "parameters": {
                "type": "object",
                "properties": {
                    "city": {
                        "type": "string",
                        "description": "City name"
                    }
                },
                "required": ["city"],
            },
        },
    }
]


if __name__ == "__main__":

    client = OpenAICompletionClient(
        api_key="YOUR_API_KEY",
        model="gpt-4.1-mini",
    )

    result = client.run_with_tools(
        user_message="What's the weather in Sydney?",
        tools=TOOLS,
        tool_implementations={
            "get_weather": get_weather
        },
        system_prompt="You are a helpful assistant.",
    )

    print(result)
